rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isCampaignMember(campaignId) {
      return signedIn() &&
        request.auth.uid in get(/databases/$(database)/documents/campaigns/$(campaignId)).data.playerIds;
    }

    function isDmParticipant() {
      return signedIn() &&
        (request.auth.uid == resource.data.senderId || request.auth.uid == resource.data.recipientId);
    }

    match /users/{userId} {
      allow read: if signedIn() && request.auth.uid == userId;
      allow create, update: if signedIn() && request.auth.uid == userId;
    }

    match /characters/{userId} {
      allow read: if signedIn() && request.auth.uid == userId;
      allow create: if signedIn() && request.auth.uid == userId;
      allow update, delete: if false;
    }

    match /campaigns/{campaignId} {
      allow read: if isCampaignMember(campaignId);
      allow create: if signedIn();
      allow update, delete: if false;

      match /messages/{messageId} {
        allow read: if isCampaignMember(campaignId);
        allow write: if false;
      }

      match /dms/{dmId} {
        allow read: if isDmParticipant();
        allow write: if false;
      }

      match /worldBible/{documentId} {
        allow read: if isCampaignMember(campaignId);
        allow write: if false;
      }
    }
  }
}
